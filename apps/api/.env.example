# TradeGuard AI API
APP_NAME=TradeGuard AI
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Database (docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://tradeguard:tradeguard@localhost:5433/tradeguard

# Redis
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# Phase 2 — provider mode (auto uses live APIs when keys are set)
MARKET_DATA_PROVIDER=auto
EMBEDDING_PROVIDER=auto
STORAGE_BACKEND=auto
MEMORY_STORE_PATH=.data/tradeguard_store.json
MARKET_REFRESH_INTERVAL_MINUTES=15
PAPER_TRADE_GOAL=100

# LLM — Cursor Composer 2.5 (default) or OpenAI / Anthropic
# Composer 2.5 requires CURSOR_API_KEY + local Cursor CLI bridge (dev) or CURSOR_CLOUD_REPO_URL (prod)
CURSOR_API_KEY=
CURSOR_WORKSPACE=
CURSOR_CLOUD_REPO_URL=
LLM_MODEL=composer-2.5
LLM_PROVIDER=cursor
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings for RAG (mock when OPENAI_API_KEY empty)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Market data (mock when POLYGON_API_KEY empty)
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
FRED_API_KEY=

# News / web search (mock when no key; auto prefers Tavily over Polygon)
NEWS_PROVIDER=auto
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_NEWS_DAYS=3

# Robinhood MCP (mock when URL empty; set ROBINHOOD_MCP_ENABLED=true to use MCP portfolio)
MCP_PROVIDER=auto
ROBINHOOD_MCP_URL=
ROBINHOOD_MCP_ENABLED=false

# Risk defaults
RISK_MAX_TRADE_USD=250
RISK_MAX_DAILY_LOSS_USD=50
RISK_MAX_SINGLE_NAME_PCT=20
RISK_MAX_TECH_SECTOR_PCT=30
RISK_REQUIRE_MANUAL_APPROVAL=true
RISK_ALLOW_OPTIONS=false

# Phase 8 — observability & compliance
AUDIT_EXPORT_MAX_DAYS=90
PLATFORM_LATENCY_THRESHOLD_MS=2000
MODEL_DRIFT_THRESHOLD=0.05
PLATFORM_HEALTH_CHECK_ENABLED=true

# Phase 9 — product & UX
PUSH_NOTIFICATIONS_ENABLED=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@tradeguard.ai

# Phase 7 — execution expansion
MULTI_BROKER_ENABLED=true
DEFAULT_BROKER_ID=robinhood_agentic
OPTIONS_WORKFLOW_ENABLED=true
RISK_MAX_OPTION_TRADE_USD=100
TAX_LOT_TRACKING_ENABLED=true
WASH_SALE_WINDOW_DAYS=30

# Phase 6 — intelligence (NEWS_PROVIDER / TAVILY_* configured above)
SEC_FILINGS_ENABLED=true
REGIME_DETECTION_ENABLED=true
ML_RETRAIN_MIN_TRADES=10

AUTH_PROVIDER=auto
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
ALERT_EMAIL_FROM=

CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Phase 4 — monitoring & alerts (mock when SLACK_WEBHOOK_URL empty)
ALERT_PROVIDER=auto
MONITORING_ENABLED=true
MONITORING_INTERVAL_MINUTES=5
TRADING_HALT_ON_DAILY_LOSS=true
MAX_DRAWDOWN_ALERT_PCT=8
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Phase 4.2 — semi-automated strategies
STRATEGIES_ENABLED=true
STRATEGIES_AUTO_EXECUTE=true
STRATEGY_EVAL_INTERVAL_MINUTES=30

# Phase 4.3 — performance validation gate (blocks Phase 4.4 automation)
VALIDATION_GATE_ENABLED=true
VALIDATION_DEV_BYPASS=false
VALIDATION_ALLOW_DEMO_SEED=true
VALIDATION_MIN_MONTHS=3
VALIDATION_MIN_SHARPE=0.5
VALIDATION_MAX_DRAWDOWN_PCT=15
VALIDATION_MIN_WIN_RATE=45
VALIDATION_MIN_TOTAL_PNL=0
VALIDATION_MAX_RULE_VIOLATIONS=10
VALIDATION_MIN_FILLED_TRADES=20
VALIDATION_STARTING_CAPITAL=10000

# Phase 4.4 — constrained automation
AUTOMATION_FEATURE_ENABLED=true
AUTOMATION_MAX_DAILY_TRADES=5
